# NVIDIA API
NVIDIA_API_KEY=nv_your_nvidia_api_key_here

# Telegram API
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Google Drive Info
GOOGLE_DRIVE_INPUT_FOLDER_ID=drive_folder_id_here

# Social Media Tokens
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_id_here

# The system also expects generic files (e.g. `youtube_credentials.json`, `service_account.json`)
# stored in the repository root or securely injected via GitHub Actions.
